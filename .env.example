# StayView Configuration
# ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is for developers, Raspberry Pi, and cloud deployments.
# Non-technical users running the .exe should use config.txt instead.

# ── Multi-property format (recommended) ───────────────────────
# Add as many properties as needed by incrementing the number.

PROPERTY_1_NAME=Scottburgh Beach House
PROPERTY_1_LOCATION=Scottburgh, KwaZulu-Natal
PROPERTY_1_AIRBNB=https://www.airbnb.com/calendar/ical/YOUR_ID.ics?t=YOUR_TOKEN
PROPERTY_1_BOOKING=https://ical.booking.com/v1/export?t=YOUR_TOKEN
PROPERTY_1_LEKKESLAAP=https://www.lekkeslaap.co.za/suppliers/icalendar.ics?t=YOUR_TOKEN
PROPERTY_1_NIGHTLY_RATE=1200
PROPERTY_1_CURRENCY=ZAR
PROPERTY_1_MIN_NIGHTS=2
PROPERTY_1_MAX_GUESTS=8
PROPERTY_1_DESCRIPTION=A beautiful beachfront property.
PROPERTY_1_PHOTO_URL=

# PROPERTY_2_NAME=Durban City Apartment
# PROPERTY_2_LOCATION=Durban, KwaZulu-Natal
# PROPERTY_2_AIRBNB=
# PROPERTY_2_BOOKING=
# PROPERTY_2_LEKKESLAAP=
# PROPERTY_2_NIGHTLY_RATE=950
# PROPERTY_2_CURRENCY=ZAR
# PROPERTY_2_MIN_NIGHTS=1
# PROPERTY_2_MAX_GUESTS=4

# ── Legacy single-property format (still supported) ───────────
# If you have an existing setup, these still work.
# Remove or comment out if using the multi-property format above.

# ICAL_AIRBNB=
# ICAL_BOOKING=
# ICAL_LEKKESLAAP=
# PROPERTY_NAME=My Property
# PROPERTY_LOCATION=
# NIGHTLY_RATE=0
# CURRENCY=ZAR
# MIN_NIGHTS=1
# MAX_GUESTS=10

# ── Auto-refresh ───────────────────────────────────────────────
# How often the server re-fetches all calendars (minutes).
# Set to 0 to disable. Default: 120 (every 2 hours).
POLL_INTERVAL_MINUTES=120
